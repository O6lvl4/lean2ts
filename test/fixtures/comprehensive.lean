import Init

-- lean2ts 包括的テスト: Lean 4 の主要機能をカバー

-- ========================================
-- 1. 基本構造体（パラメータなし）
-- ========================================
structure Point where
  x : Nat
  y : Nat

-- ========================================
-- 2. デフォルト値付き構造体
-- ========================================
structure Config where
  name : String
  maxRetries : Nat := 3
  verbose : Bool := false

-- ========================================
-- 3. 型パラメータ付き構造体（ジェネリクス）
-- ========================================
structure Wrapper (α : Type) where
  value : α
  label : String

-- ========================================
-- 4. 複数型パラメータ付き構造体
-- ========================================
structure KeyValue (K V : Type) where
  key : K
  val : V

-- ========================================
-- 5. 基本帰納型（enum 相当）
-- ========================================
inductive Color where
  | red
  | green
  | blue

-- ========================================
-- 6. フィールド付き帰納型（判別共用体）
-- ========================================
inductive Shape where
  | circle (radius : Nat)
  | rect (width : Nat) (height : Nat)
  | point

-- ========================================
-- 7. 型パラメータ付き帰納型
-- ========================================
inductive MyOption (α : Type) where
  | none
  | some (value : α)

-- ========================================
-- 8. 再帰的帰納型
-- ========================================
inductive MyList (α : Type) where
  | nil
  | cons (head : α) (tail : MyList α)

-- ========================================
-- 9. 基本 def
-- ========================================
def double (n : Nat) : Nat := n * 2

-- ========================================
-- 10. 複数引数 def
-- ========================================
def add (x y : Nat) : Nat := x + y

-- ========================================
-- 11. 型パラメータ付き def
-- ========================================
def identity (α : Type) (x : α) : α := x

-- ========================================
-- 12. implicit 型パラメータ付き def
-- ========================================
def listHead {α : Type} (xs : List α) (default : α) : α :=
  match xs with
  | [] => default
  | x :: _ => x

-- ========================================
-- 13. 基本定理（等式）
-- ========================================
theorem add_zero (n : Nat) : n + 0 = n := by simp

-- ========================================
-- 14. 含意を含む定理
-- ========================================
theorem pos_implies_nonzero (n : Nat) : n > 0 → n ≠ 0 := by omega

-- ========================================
-- 15. And を含む定理
-- ========================================
theorem and_comm_prop (a b : Prop) : a ∧ b → b ∧ a := by
  intro ⟨ha, hb⟩; exact ⟨hb, ha⟩

-- ========================================
-- 16. Or を含む定理
-- ========================================
theorem zero_or_pos (n : Nat) : n = 0 ∨ n > 0 := by omega

-- ========================================
-- 17. List を使った def
-- ========================================
def myLength {α : Type} (xs : List α) : Nat :=
  match xs with
  | [] => 0
  | _ :: rest => 1 + myLength rest

-- ========================================
-- 18. Option を使った def
-- ========================================
def orDefault {α : Type} (x : Option α) (d : α) : α :=
  match x with
  | none => d
  | some v => v

-- ========================================
-- 19. Prod (タプル)
-- ========================================
def swap {α β : Type} (p : α × β) : β × α := (p.2, p.1)

-- ========================================
-- 20. 型クラスを使う def
-- ========================================
def stringify [ToString α] (x : α) : String := toString x

-- ========================================
-- 21. ネストした型
-- ========================================
def flattenOpt {α : Type} (x : Option (Option α)) : Option α :=
  match x with
  | none => none
  | some inner => inner

-- ========================================
-- 22. 複数制約の型クラス
-- ========================================
def addAndShow [Add α] [ToString α] (x y : α) : String :=
  toString (x + y)
